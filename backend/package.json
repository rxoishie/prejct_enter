{
  "name": "smartirri-backend",
  "version": "1.0.0",
  "description": "Backend API for SmartIrriPro",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "migrate": "node src/db/migrate.js",
    "seed": "node src/db/seed.js",
    "backup:db": "bash scripts/db-backup.sh",
    "restore:db": "bash scripts/db-restore.sh",
    "drill:restore": "bash scripts/restore-drill-report.sh",
    "smoke": "bash scripts/smoke.sh",
    "test:api": "node --test tests/api.integration.test.mjs",
    "test:rate-limit": "node --test tests/rate-limit.integration.test.mjs",
    "test:local-ci": "bash scripts/test-local-ci.sh"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
